💻 Mini Project – Package Audit

Create package-audit.sh

#!/bin/bash

mkdir -p reports

REPORT="reports/package-report.txt"

echo "===== Package Audit =====" > "$REPORT"

echo "Generated: $(date)" >> "$REPORT"

echo "" >> "$REPORT"

echo "Upgradeable Packages:" >> "$REPORT"

apt list --upgradable >> "$REPORT"

echo "" >> "$REPORT"

echo "Installed Git Version:" >> "$REPORT"

git --version >> "$REPORT" 2>/dev/null

echo "" >> "$REPORT"

echo "Disk Usage:" >> "$REPORT"

df -h >> "$REPORT"

echo "Audit Complete"
