💻 Mini Project – Linux Security Audit

Create

security-audit.sh
#!/bin/bash

mkdir -p reports

REPORT="reports/security-report.txt"

echo "Security Report" > "$REPORT"

echo "Generated: $(date)" >> "$REPORT"

echo "" >> "$REPORT"

echo "Users Logged In" >> "$REPORT"

who >> "$REPORT"

echo "" >> "$REPORT"

echo "Firewall" >> "$REPORT"

sudo ufw status >> "$REPORT"

echo "" >> "$REPORT"

echo "Listening Ports" >> "$REPORT"

ss -tulnp >> "$REPORT"

echo "" >> "$REPORT"

echo "Failed Login Attempts" >> "$REPORT"

sudo grep "Failed" /var/log/auth.log >> "$REPORT"

echo "Audit Completed"
