🛠️ Task 1 – Install Git

Ubuntu

sudo apt update
sudo apt install git -y

Check version

git --version
🛠️ Task 2 – Configure Git
git config --global user.name "Sachin KL"

git config --global user.email "your-email@example.com"

Verify

git config --list
🛠️ Task 3 – Create Repository
mkdir git-demo

cd git-demo

git init

Check

git status
🛠️ Task 4 – Create Files
echo "# My DevOps Project" > README.md

touch app.sh

Status

git status
🛠️ Task 5 – Add Files

Single file

git add README.md

All files

git add .

Check

git status
🛠️ Task 6 – Commit
git commit -m "Initial commit"

View history

git log

Compact log

git log --oneline
🛠️ Task 7 – Modify Files

Append text

echo "Welcome to Git" >> README.md

Check changes

git diff

Commit changes

git add README.md

git commit -m "Updated README"
🛠️ Task 8 – Clone Repository
git clone https://github.com/username/repository.git
🛠️ Task 9 – Create .gitignore
*.log
*.tmp
node_modules/
.env
dist/

Verify ignored files

git status
🛠️ Task 10 – Git Help
git help

git help commit

git help log
