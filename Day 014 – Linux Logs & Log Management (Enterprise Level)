💻 Mini Project – Log Analyzer

Create log-analyzer.sh

#!/bin/bash

LOG="/var/log/syslog"

echo "===== Log Analysis ====="

echo "Total Lines:"
wc -l "$LOG"

echo ""

echo "Errors:"
grep -ic error "$LOG"

echo ""

echo "Warnings:"
grep -ic warning "$LOG"

echo ""

echo "Failed:"
grep -ic failed "$LOG"
