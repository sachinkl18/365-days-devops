💻 Mini Project – Disk Audit

Create disk-audit.sh

#!/bin/bash

mkdir -p reports

REPORT="reports/storage-report.txt"

echo "===== Storage Audit =====" > "$REPORT"
echo "Generated: $(date)" >> "$REPORT"

echo "" >> "$REPORT"
lsblk >> "$REPORT"

echo "" >> "$REPORT"
df -h >> "$REPORT"

echo "" >> "$REPORT"
free -h >> "$REPORT"

echo "" >> "$REPORT"
swapon --show >> "$REPORT"

echo "Storage report generated."
