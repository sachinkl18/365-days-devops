💻 Mini Project – Process Monitor

Create process-monitor.sh

#!/bin/bash

mkdir -p reports

REPORT="reports/process-report.txt"

echo "===== Process Report =====" > "$REPORT"
echo "Generated: $(date)" >> "$REPORT"

echo "" >> "$REPORT"
echo "Top CPU Processes:" >> "$REPORT"
ps -eo pid,%cpu,comm --sort=-%cpu | head >> "$REPORT"

echo "" >> "$REPORT"
echo "Top Memory Processes:" >> "$REPORT"
ps -eo pid,%mem,comm --sort=-%mem | head >> "$REPORT"

echo "" >> "$REPORT"
echo "System Load:" >> "$REPORT"
uptime >> "$REPORT"

echo "Process report generated."
