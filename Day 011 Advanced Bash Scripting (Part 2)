🛠️ Step 1 – Arrays

Create arrays.sh

#!/bin/bash

servers=("web01" "web02" "db01" "cache01")

echo "Total Servers: ${#servers[@]}"

echo "First Server: ${servers[0]}"

echo "All Servers:"

for server in "${servers[@]}"
do
    echo "$server"
done

Run:

chmod +x arrays.sh
./arrays.sh
🛠️ Step 2 – String Operations

Create strings.sh

#!/bin/bash

NAME="Senior DevOps Engineer"

echo "Original : $NAME"

echo "Length : ${#NAME}"

echo "Upper : ${NAME^^}"

echo "Lower : ${NAME,,}"

echo "Replace : ${NAME/Engineer/Architect}"
