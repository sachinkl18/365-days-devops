💻 Mini Project – Disk Health Report

Create disk-health.sh

#!/bin/bash

REPORT="disk-health-report.txt"

echo "===== Disk Health Report =====" > "$REPORT"
echo "Generated: $(date)" >> "$REPORT"

echo "" >> "$REPORT"
echo "Disk Usage:" >> "$REPORT"
df -h >> "$REPORT"

echo "" >> "$REPORT"
echo "Block Devices:" >> "$REPORT"
lsblk >> "$REPORT"

echo "" >> "$REPORT"
echo "Mounted Filesystems:" >> "$REPORT"
findmnt >> "$REPORT"

echo "" >> "$REPORT"
echo "Memory & Swap:" >> "$REPORT"
free -h >> "$REPORT"

echo "" >> "$REPORT"
echo "Inodes:" >> "$REPORT"
df -i >> "$REPORT"

echo ""
echo "Report generated: $REPORT"
