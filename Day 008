💻 Mini Project – Service Health Monitor

Create:

service-monitor.sh

#!/bin/bash

REPORT="service-report.txt"

echo "===== Service Health Report =====" > "$REPORT"
echo "Generated: $(date)" >> "$REPORT"

echo "" >> "$REPORT"
echo "Running Services:" >> "$REPORT"
systemctl list-units --type=service --state=running >> "$REPORT"

echo "" >> "$REPORT"
echo "Failed Services:" >> "$REPORT"
systemctl --failed >> "$REPORT"

echo "" >> "$REPORT"
echo "System Boot Time:" >> "$REPORT"
systemd-analyze >> "$REPORT"

echo ""
echo "Report saved to $REPORT"
