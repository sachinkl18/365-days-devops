💻 Mini Project – Package Health Report

Create:

package-health.sh
#!/bin/bash

REPORT="package-report.txt"

echo "Package Health Report" > $REPORT

echo "Generated: $(date)" >> $REPORT

echo "" >> $REPORT

echo "Git Version:" >> $REPORT
git --version >> $REPORT

echo "" >> $REPORT

echo "Curl Version:" >> $REPORT
curl --version | head -1 >> $REPORT

echo "" >> $REPORT

echo "Installed Packages:" >> $REPORT
dpkg -l | head -20 >> $REPORT

echo "" >> $REPORT

echo "Repository Status:" >> $REPORT
apt-cache policy >> $REPORT

echo "Report saved."
