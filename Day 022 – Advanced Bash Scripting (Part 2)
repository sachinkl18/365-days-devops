💻 Mini Project – Server Health Monitor

Create server-health.sh

#!/bin/bash

mkdir -p reports

REPORT="reports/server-health-$(date +%F-%H%M).txt"

{
echo "========== SERVER HEALTH =========="
echo "Date: $(date)"
echo ""
echo "Hostname: $(hostname)"
echo "Uptime:"
uptime
echo ""
echo "CPU Load:"
top -bn1 | head -5
echo ""
echo "Memory:"
free -h
echo ""
echo "Disk:"
df -h
echo ""
echo "Top 5 CPU Processes:"
ps -eo pid,%cpu,comm --sort=-%cpu | head -6
echo ""
echo "Top 5 Memory Processes:"
ps -eo pid,%mem,comm --sort=-%mem | head -6
} > "$REPORT"

echo "Health report generated: $REPORT"
