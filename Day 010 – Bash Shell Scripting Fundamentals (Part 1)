Step 2 – Variables

Create variables.sh

#!/bin/bash

NAME="Sachin"

COMPANY="OpenAI"

echo "Name : $NAME"

echo "Company : $COMPANY"

DATE=$(date)

echo "Today : $DATE"

HOST=$(hostname)

echo "Hostname : $HOST"
Step 3 – User Input
#!/bin/bash

read -p "Enter your name : " NAME

echo "Welcome $NAME"
Step 4 – Command Line Arguments
#!/bin/bash

echo "First Argument : $1"

echo "Second Argument : $2"

echo "Total Arguments : $#"

Run

./script.sh Sachin DevOps

Output

First Argument : Sachin

Second Argument : DevOps
Step 5 – If Else

Create conditions.sh

#!/bin/bash

read -p "Enter Age : " AGE

if [ $AGE -ge 18 ]
then
    echo "Eligible"
else
    echo "Not Eligible"
fi
Step 6 – Case Statement
#!/bin/bash

read -p "Choose Option (start|stop|restart): " OPTION

case $OPTION in
    start)
        echo "Starting Service"
        ;;
    stop)
        echo "Stopping Service"
        ;;
    restart)
        echo "Restarting Service"
        ;;
    *)
        echo "Invalid Option"
        ;;
esac
Step 7 – For Loop

Create loops.sh

#!/bin/bash

for i in {1..10}
do
    echo "Iteration $i"
done
Step 8 – While Loop
#!/bin/bash

COUNT=1

while [ $COUNT -le 5 ]
do
    echo $COUNT
    ((COUNT++))
done
Step 9 – Functions

Create functions.sh

